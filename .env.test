# Test Environment Configuration
# Used for running tests

# RSK Configuration (testnet or mainnet)
RSK_RPC_URL=https://public-node.rsk.co
RSK_CHAIN_ID=30

# Test contract addresses (or use mocks)
MOC_PLATFORM_ADDRESS=0x4854a59D4B2b1E7A6B5D8F5C0E5B5E5A5D5C5B5A
MOC_HOLDER_ADDRESS=0x5a5D5C5B5A5D5C5B5A5D5C5B5A5D5C5B5A5D5C5B
DOC_TOKEN_ADDRESS=0xE700691Da7B9851F2F35F8B8182C69C53Cca9d9

# Telegram Bot (Test bot - optional)
TELEGRAM_BOT_TOKEN=test_bot_token
TELEGRAM_ADMIN_ID=123456789

# Alert Thresholds (for testing)
WARNING_THRESHOLD=180
CRITICAL_THRESHOLD=160
LIQUIDATION_THRESHOLD=150

# Polling (faster for tests)
POLL_INTERVAL_MINUTES=5
BATCH_SIZE=10

# Database (test database)
DATABASE_PATH=/home/ovservant/projects/rsk-collateral-monitor/data/test_collateral_monitor.db

# Logging (verbose for tests)
LOG_LEVEL=DEBUG
